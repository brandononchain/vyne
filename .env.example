# ── Vyne Environment Variables ─────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# Railway will auto-populate DATABASE_URL and REDIS_URL
# when you add PostgreSQL and Redis plugins.

# ── Database (Railway PostgreSQL) ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/vyne?schema=public"

# ── Redis (Railway Redis) ─────────────────────────────────────────────
# Used for BullMQ job queue (workflow execution)
REDIS_URL="redis://default:password@localhost:6379"

# ── Clerk Authentication ──────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook signing secret (for /api/webhooks/clerk)
# Get this from Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Clerk Route Configuration ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ── Anthropic (LLM Engine) ────────────────────────────────────────────
# Powers all agent workflows via LangGraph + @langchain/anthropic
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ── Tavily Search (Optional) ─────────────────────────────────────────
# Enhances the web_search tool with high-quality search results
# Get your key from https://tavily.com — free tier available
TAVILY_API_KEY="tvly-..."

# ── Application ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

RAILWAY_TOKEN=8dafdd1b-6135-4e04-b8db-2e98bdf41654