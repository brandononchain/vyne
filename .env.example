# ── Vyne Environment Variables ─────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# Railway will auto-populate DATABASE_URL and REDIS_URL
# when you add PostgreSQL and Redis plugins.

# ── Database (Railway PostgreSQL) ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/vyne?schema=public"

# ── Redis (Railway Redis) ─────────────────────────────────────────────
# Used for BullMQ job queue (workflow execution)
REDIS_URL="redis://default:password@localhost:6379"

# ── Clerk Authentication ──────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook signing secret (for /api/webhooks/clerk)
# Get this from Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Clerk Route Configuration ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ── Anthropic (LLM Engine) ────────────────────────────────────────────
# Powers all agent workflows via LangGraph + @langchain/anthropic
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: override the model used by the engine + workflow generator.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Google Gemini (logo generation) ───────────────────────────────────
# Only required for /api/generate-logo (image generation).
GEMINI_API_KEY="..."

# ── Tavily (agent web-search tool) ────────────────────────────────────
# Enables the real web_search tool for agents. Without it, web_search
# returns an "unconfigured" notice instead of fabricated results.
# Get a key at https://app.tavily.com/
TAVILY_API_KEY="tvly-..."

# ── Application ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
